      "SurvivalStatsConfig": { "$path": "assets/config/SurvivalStatsConfig.model.json" }
    },
    "ServerScriptService": {
      "Demo": { "$path": "demo/server" }
    },
    "StarterGui": {
      "$className": "StarterGui",
      "SurvivalHud": { "$path": "assets/hud/SurvivalHud.model.json" }
